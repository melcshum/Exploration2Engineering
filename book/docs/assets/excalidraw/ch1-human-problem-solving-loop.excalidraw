      "id": "no-label",
      "type": "text",
      "x": 920,
      "y": 300,
      "width": 80,
      "height": 30,
      "strokeColor": "transparent",
      "backgroundColor": "transparent",
      "fontSize": 14,
      "fontFamily": "Arial",
      "color": "#c2185b",
      "text": "No"
