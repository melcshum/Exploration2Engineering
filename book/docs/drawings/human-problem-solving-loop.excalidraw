        "text": "Action",
        "color": "#e65100",
        "fontSize": 18,
        "fontFamily": "Arial",
        "textAlign": "center",
        "verticalTextAlign": "middle"
      }
    },
    {
      "id": "a2",
      "type": "arrow",
      "x": 400,
      "y": 235,
      "width": 60,
      "height": 0,
      "strokeColor": "#37474f",
      "strokeWidth": 2,
      "endArrowhead": "arrow",
      "points": [[0, 0], [60, 0]]
    },
    {
      "id": "observation",
      "type": "rectangle",
      "x": 460,
      "y": 200,
      "width": 140,
      "height": 70,
      "fillStyle": "solid",
      "backgroundColor": "#e8f5e9",
      "strokeColor": "#2e7d32",
      "strokeWidth": 2,
      "roundness": { "basic": 6, "edit": 6 },
      "label": {
        "text": "Observation",
        "color": "#2e7d32",
        "fontSize": 18,
        "fontFamily": "Arial",
        "textAlign": "center",
        "verticalTextAlign": "middle"
      }
