{
  "type": "excalidraw",
  "version": 2,
  "source": "https://excalidraw.com",
  "elements": [
    {
      "id": "thought",
      "type": "rectangle",
      "x": 60,
      "y": 200,
      "width": 140,
      "height": 70,
      "fillStyle": "solid",
      "backgroundColor": "#e3f2fd",
      "strokeColor": "#1565c0",
      "strokeWidth": 2,
      "roundness": { "basic": 6, "edit": 6 },
      "label": {
        "text": "Thought",
        "color": "#1565c0",
        "fontSize": 18,
        "fontFamily": "Arial",
        "textAlign": "center",
        "verticalTextAlign": "middle"
      }
    },
    {
      "id": "a1",
      "type": "arrow",
      "x": 200,
      "y": 235,
      "width": 60,
      "height": 0,
      "strokeColor": "#37474f",
      "strokeWidth": 2,
      "endArrowhead": "arrow",
      "points": [[0, 0], [60, 0]]
    },
    {
      "id": "action",
      "type": "rectangle",
      "x": 260,
      "y": 200,
      "width": 140,
      "height": 70,
      "fillStyle": "solid",
      "backgroundColor": "#fff3e0",
      "strokeColor": "#e65100",
      "strokeWidth": 2,
