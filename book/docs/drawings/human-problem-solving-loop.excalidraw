      "x": 660,
      "y": 200,
      "width": 120,
      "height": 70,
      "fillStyle": "solid",
      "backgroundColor": "#fce4ec",
      "strokeColor": "#c2185b",
      "strokeWidth": 2,
      "label": {
        "text": "Solved?",
        "color": "#c2185b",
        "fontSize": 16,
        "fontFamily": "Arial",
        "textAlign": "center",
        "verticalTextAlign": "middle"
      }
    },
    {
      "id": "yes",
      "type": "text",
      "x": 800,
      "y": 215,
      "width": 80,
      "height": 40,
      "strokeColor": "transparent",
      "backgroundColor": "transparent",
      "fontSize": 14,
      "fontFamily": "Arial",
      "color": "#2e7d32",
      "text": "Yes → Done"
