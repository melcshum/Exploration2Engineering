    {
      "id": "a3",
      "type": "arrow",
      "x": 600,
      "y": 235,
      "width": 60,
      "height": 0,
      "strokeColor": "#37474f",
      "strokeWidth": 2,
      "endArrowhead": "arrow",
      "points": [[0, 0], [60, 0]]
    },
    {
      "id": "solved",
